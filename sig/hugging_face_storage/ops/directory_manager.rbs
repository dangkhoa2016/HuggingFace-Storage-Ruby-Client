module HuggingFaceStorage
  class DirectoryManager
    def initialize: (
      api_client: ApiClient,
      xet_uploader: XetUploader,
      xet_downloader: XetDownloader,
      file_manager: FileManager,
      bucket_id: String,
      crud_service: DirectoryCrudService,
      transfer_service: DirectoryTransferService,
      copy_service: DirectoryCopyService,
      ?logger: HFLogger,
      ?config: Configuration
    ) -> void

    def create: (String path, ?cancel_token: CancelToken?) -> bool

    def delete: (
      (String | Array[String]) path,
      ?recursive: bool,
      ?cancel_token: CancelToken?,
      ?raise_on_partial_failure: bool
    ) -> (bool | BatchResult)

    def exists?: (String path) -> bool

    def list: (?prefix: String?) -> Array[DirInfo]
    def list_files: (String path, ?recursive: bool) -> Array[FileInfo]

    def metadata: (String path) -> DirInfo

    def download: (
      String path, String local_dir,
      ?parallel: Integer,
      ?cancel_token: CancelToken?
    ) -> Hash[Symbol, untyped]

    def upload: (
      String local_dir, String remote_path,
      ?exclude: String?,
      ?cancel_token: CancelToken?
    ) -> untyped

    def snapshot_download: (
      String remote_path, String local_dir,
      ?verify: bool
    ) -> Hash[Symbol, untyped]

    def move: (String source_path, String destination_path) -> Hash[Symbol, untyped]
    def rename: (String old_path, String new_path) -> Hash[Symbol, untyped]

    def copy: (
      (String | Array[String]) source_path, String destination_path,
      ?source_type: String?, ?source_repo: String?,
      ?revision: String, ?exclude: String?, ?overwrite: bool
    ) -> untyped

    def copy_from_tree: (
      source_type: String, source_repo: String, tree: (String | Array[Hash[String, untyped]]),
      ?source_prefix: String?, ?destination_prefix: String?,
      ?exclude: String?, ?overwrite: bool, ?cancel_token: CancelToken?
    ) -> Hash[Symbol, untyped]

    def copy_from_repo: (
      source_type: String, source_repo: String,
      ?source_path: String?, ?destination_prefix: String?,
      ?revision: String, ?exclude: String?, ?overwrite: bool,
      ?cancel_token: CancelToken?
    ) -> Hash[Symbol, untyped]

    def copy_folders: (
      folders: Array[Hash[Symbol, untyped]],
      ?overwrite: bool,
      ?on_progress: Proc?,
      ?cancel_token: CancelToken?,
      ?raise_on_partial_failure: bool
    ) -> Hash[Symbol, untyped]
  end
end
